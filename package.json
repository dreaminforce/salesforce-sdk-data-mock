{
  "name": "salesforce-sdk-data-mock",
  "version": "0.2.1",
  "description": "Generic in-memory Vite mock for @salesforce/platform-sdk Data SDK GraphQL operations.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "salesforce",
    "vite",
    "mock",
    "graphql",
    "uiapi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dreaminforce/salesforce-sdk-data-mock.git"
  },
  "homepage": "https://github.com/dreaminforce/salesforce-sdk-data-mock#readme",
  "bugs": {
    "url": "https://github.com/dreaminforce/salesforce-sdk-data-mock/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "graphql": "^16.11.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "peerDependencies": {
    "@salesforce/platform-sdk": ">=10.24.0 <12",
    "vite": "*"
  },
  "peerDependenciesMeta": {
    "@salesforce/platform-sdk": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
